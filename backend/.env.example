# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_SECRET=change_this_to_a_256_bit_random_string

# Base de données
DB_HOST=mysql
DB_PORT=3306
DB_NAME=incident_reporter
DB_USER=incident_user
DB_PASSWORD=incident_pass_local
DB_ROOT_PASSWORD=root_pass_local

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_local

# JWT
JWT_SECRET=change_this_to_another_256_bit_random_string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=/var/www/html/storage/uploads/incidents
UPLOAD_PUBLIC_URL=http://localhost:8080/storage/incidents

# Mail (local : log ou désactivé)
MAIL_DRIVER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@incident-reporter.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=60
