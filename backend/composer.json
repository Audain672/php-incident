{
  "name": "incident-reporter/backend",
  "description": "Incident Reporter — PHP REST API",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^6.9",
    "ramsey/uuid": "^4.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox",
    "start": "docker compose up -d"
  },
  "config": {
    "audit": {
      "ignore": ["PKSA-y2cr-5h3j-g3ys"]
    }
  }
}
